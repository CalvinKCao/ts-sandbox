	keywords = {Computer Science - Computer Vision and Pattern Recognition},
	file = {PDF:C\:\\Users\\kevin\\Zotero\\storage\\VLQBS7WQ\\Kinakh and Voloshynovskiy - 2025 - Binary Diffusion Probabilistic Model.pdf:application/pdf},
