*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5
*.hdf5
**/checkpoints/
**/pre-trained-models/

# -----------------------------------------------------------------------------
# TensorFlow/TensorBoard
# -----------------------------------------------------------------------------
**/logs/
*.tfevents.*
events.out.*

# -----------------------------------------------------------------------------
# Academic Papers (local reference only)
# -----------------------------------------------------------------------------
papers/
*.pdf

# Large txt files (papers converted to text)
models/ViTime-main/*.txt
models/pathformer-main/*.txt
models/TFDNet-main/*.txt
models/Time-Series-Library-main/*.txt

# -----------------------------------------------------------------------------
# Logs and Databases
# -----------------------------------------------------------------------------
*.log
*.db
*.sqlite
*.sqlite3
training.log
optuna_study.db

# -----------------------------------------------------------------------------
# Images and Visualizations (regeneratable)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.svg
**/visualizations/
**/figs/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Temporary Files
