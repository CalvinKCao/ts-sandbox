*.tmp
*.temp
*.bak
*.npy

# -----------------------------------------------------------------------------
# Duplicate Datasets in Model Folders
# -----------------------------------------------------------------------------
models/TFDNet-main/Datasets/
models/pathformer-main/datasets/
models/Time-Series-Library-main/dataset/

